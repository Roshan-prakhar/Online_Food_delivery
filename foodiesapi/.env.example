# ========================================
# Foodies API - Environment Variable Template
# ========================================
# Copy this file to .env.local and fill in real values.
# Never commit .env.local with real values.

# --- PostgreSQL ---
# For local: jdbc:postgresql://localhost:5432/foodies
# For production (Neon): jdbc:postgresql://<host>/foodies?sslmode=require
DATABASE_URL=jdbc:postgresql://localhost:5432/foodies
DB_USERNAME=postgres
DB_PASSWORD=postgres

# --- JWT (generate any random 64+ char hex string) ---
JWT_SECRET=replace_with_64_char_random_hex_string

# --- Cloudinary (free, no card) https://cloudinary.com ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=foodies

# --- Razorpay Test Mode (free, no KYC) https://dashboard.razorpay.com ---
RAZORPAY_KEY=rzp_test_your_key
RAZORPAY_SECRET=your_secret

# --- CORS (production only) ---
# Comma-separated allowed origins. Leave unset for local (defaults to localhost:5173,5174)
# CORS_ALLOWED_ORIGINS=https://foodies-customer.netlify.app,https://foodies-admin.netlify.app

# --- Port (Render injects this; not needed locally) ---
# PORT=8080
